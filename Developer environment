<span class="cmd">git config</span> --global user.email <span class="str">"you@email.com"</span>
<span class="comment"># Inside any project folder:</span>
<span class="cmd">git init</span> && <span class="cmd">git add</span> . && <span class="cmd">git commit</span> -m <span class="str">"first commit"</span></pre>
          </div>
        </div>
      </div>
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
