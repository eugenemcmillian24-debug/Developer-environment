    <p>your dev environment is ready.<br>go build something amazing.</p>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  const TOTAL = 14;
  let done = 0;

  function togglePhase(header) {
    const phase = header.parentElement;
    phase.classList.toggle('open');
  }

  function toggleStep(step) {
    const wasDone = step.classList.contains('done');
    step.classList.toggle('done');
    done += wasDone ? -1 : 1;
    updateProgress();
  }

  function updateProgress() {
    const pct = (done / TOTAL) * 100;
    document.getElementById('prog-fill').style.width = pct + '%';
    document.getElementById('prog-count').textContent = done + ' / ' + TOTAL + ' steps';
    
    if (done === TOTAL) {
      document.getElementById('complete-banner').classList.add('show');
      showToast('🔥 Full setup complete! Start building!');
    }
  }

  function copyCode(btn) {
    const pre = btn.closest('.code-block').querySelector('pre');
    const text = pre.innerText;
    navigator.clipboard.writeText(text).then(() => {
      btn.textContent = 'COPIED!';
      btn.classList.add('copied');
      showToast('Command copied to clipboard');
      setTimeout(() => {
        btn.textContent = 'COPY';
        btn.classList.remove('copied');
      }, 2000);
    }).catch(() => {
      // fallback
      const ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      btn.textContent = 'COPIED!';
      btn.classList.add('copied');
      showToast('Command copied!');
      setTimeout(() => { btn.textContent = 'COPY'; btn.classList.remove('copied'); }, 2000);
    });
  }

  let toastTimer;
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
  }
</script>
