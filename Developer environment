          <div class="link-grid">
            <a class="link-card" href="https://github.com" target="_blank"><span class="link-icon">🐙</span> GitHub</a>
            <a class="link-card" href="https://vercel.com" target="_blank"><span class="link-icon">▲</span> Vercel</a>
            <a class="link-card" href="https://netlify.com" target="_blank"><span class="link-icon">🌐</span> Netlify</a>
            <a class="link-card" href="https://railway.app" target="_blank"><span class="link-icon">🚂</span> Railway</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stack Reference -->
  <div class="phase phase-1" style="margin-top:28px">
    <div class="phase-header" onclick="togglePhase(this)">
      <div class="phase-num" style="background:rgba(255,255,255,0.05);color:#fff">⚡</div>
