<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DevBase — Mobile Dev Environment</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080c10;
    --panel: #0d1117;
    --border: #1e2d3d;
    --accent: #00ff88;
    --accent2: #00c6ff;
    --accent3: #ff6b6b;
    --accent4: #ffd93d;
    --text: #c9d1d9;
    --muted: #4a5568;
    --glow: 0 0 20px rgba(0,255,136,0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    font-family: 'Syne', sans-serif;
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Animated grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: 
      linear-gradient(rgba(0,255,136,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,136,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .noise {
    position: fixed;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4'/%3E%3C/filter%3E%3Crect width='512' height='512' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 20px 16px 60px;
  }

  /* Header */
  header {
    text-align: center;
    padding: 40px 0 32px;
    animation: fadeDown 0.6s ease both;
  }

  .logo-badge {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--accent);
    background: rgba(0,255,136,0.08);
    border: 1px solid rgba(0,255,136,0.2);
    padding: 5px 14px;
    border-radius: 2px;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2rem, 8vw, 3.2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -1px;
    color: #fff;
  }

  h1 span {
    color: var(--accent);
    position: relative;
  }

  h1 span::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    opacity: 0.4;
  }

  .subtitle {
    margin-top: 12px;
    color: var(--muted);
    font-size: 14px;
    font-family: 'Space Mono', monospace;
  }

  /* Progress bar */
  .progress-section {
    margin: 28px 0;
    animation: fadeUp 0.6s 0.1s ease both;
  }

  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    font-size: 12px;
    font-family: 'Space Mono', monospace;
  }

  .progress-label { color: var(--muted); }
  .progress-count { color: var(--accent); font-weight: 700; }

  .progress-bar {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    border-radius: 2px;
    transition: width 0.5s cubic-bezier(0.4,0,0.2,1);
    width: 0%;
    box-shadow: 0 0 10px rgba(0,255,136,0.5);
  }

  /* Phase sections */
  .phase {
    margin-bottom: 20px;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--panel);
    animation: fadeUp 0.6s ease both;
  }

  .phase-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 18px;
    cursor: pointer;
    user-select: none;
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid transparent;
    transition: background 0.2s;
  }

  .phase-header:hover { background: rgba(255,255,255,0.04); }
  .phase.open .phase-header { border-bottom-color: var(--border); }

  .phase-num {
    width: 28px; height: 28px;
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .phase-title {
    flex: 1;
    font-weight: 700;
    font-size: 15px;
    color: #fff;
  }

  .phase-meta {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--muted);
  }

  .phase-arrow {
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    transition: transform 0.3s;
    font-size: 12px;
  }

  .phase.open .phase-arrow { transform: rotate(180deg); }

  .phase-body {
    display: none;
    padding: 16px 18px;
  }

  .phase.open .phase-body { display: block; }

  /* Steps */
  .step {
    display: flex;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    align-items: flex-start;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .step:last-child { border-bottom: none; }

  .step-check {
    width: 20px; height: 20px;
    border: 2px solid var(--border);
    border-radius: 4px;
    flex-shrink: 0;
    margin-top: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    font-size: 11px;
    color: transparent;
  }

  .step.done .step-check {
    background: var(--accent);
    border-color: var(--accent);
    color: #000;
    box-shadow: var(--glow);
  }

  .step.done .step-title { text-decoration: line-through; opacity: 0.5; }

  .step-content { flex: 1; }
  .step-title {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
  }

  .step-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 8px;
  }

  /* Code blocks */
  .code-block {
    background: #0a0e14;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    margin-top: 8px;
  }

  .code-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--border);
  }

  .code-lang {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .copy-btn {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--accent2);
    background: none;
    border: 1px solid rgba(0,198,255,0.2);
    border-radius: 3px;
    padding: 3px 8px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 1px;
  }

  .copy-btn:hover {
    background: rgba(0,198,255,0.1);
    box-shadow: 0 0 10px rgba(0,198,255,0.2);
  }

  .copy-btn.copied {
    color: var(--accent);
    border-color: rgba(0,255,136,0.2);
  }

  pre {
    padding: 14px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    line-height: 1.7;
    overflow-x: auto;
    color: #8be9fd;
  }

  pre .comment { color: var(--muted); font-style: italic; }
  pre .cmd { color: var(--accent); }
  pre .str { color: var(--accent4); }
  pre .kw { color: #ff79c6; }

  /* Link cards */
  .link-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 8px;
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--text);
    font-size: 12px;
    transition: all 0.2s;
    font-family: 'Space Mono', monospace;
  }

  .link-card:hover {
    border-color: var(--accent2);
    background: rgba(0,198,255,0.05);
    color: var(--accent2);
  }

  .link-icon { font-size: 16px; }

  /* Stack table */
  .stack-grid {
    display: grid;
    gap: 6px;
    margin-top: 8px;
  }

  .stack-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 6px;
    font-size: 11px;
    font-family: 'Space Mono', monospace;
  }

  .stack-cell {
    padding: 8px 10px;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .stack-cell.head {
    color: var(--muted);
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .stack-cell.layer { color: var(--accent4); }
  .stack-cell.tool { color: #fff; font-weight: 700; }
  .stack-cell.desc { color: var(--muted); }

  /* Notification toast */
  .toast {
    position: fixed;
    bottom: 24px;
    right: 20px;
    background: var(--panel);
    border: 1px solid var(--accent);
    border-radius: 8px;
    padding: 12px 18px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    box-shadow: var(--glow);
    transform: translateY(80px);
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    z-index: 100;
    max-width: 260px;
  }

  .toast.show {
    transform: translateY(0);
    opacity: 1;
  }

  /* Animations */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .phase:nth-child(1) { animation-delay: 0.1s; }
  .phase:nth-child(2) { animation-delay: 0.15s; }
  .phase:nth-child(3) { animation-delay: 0.2s; }
  .phase:nth-child(4) { animation-delay: 0.25s; }
  .phase:nth-child(5) { animation-delay: 0.3s; }
  .phase:nth-child(6) { animation-delay: 0.35s; }

  /* Color themes per phase */
  .phase-1 .phase-num { background: rgba(0,255,136,0.1); color: var(--accent); }
  .phase-2 .phase-num { background: rgba(0,198,255,0.1); color: var(--accent2); }
  .phase-3 .phase-num { background: rgba(255,107,107,0.1); color: var(--accent3); }
  .phase-4 .phase-num { background: rgba(255,217,61,0.1); color: var(--accent4); }
  .phase-5 .phase-num { background: rgba(189,147,249,0.1); color: #bd93f9; }
  .phase-6 .phase-num { background: rgba(255,184,108,0.1); color: #ffb86c; }

  .phase-1 .phase-header { border-left: 3px solid var(--accent); }
  .phase-2 .phase-header { border-left: 3px solid var(--accent2); }
  .phase-3 .phase-header { border-left: 3px solid var(--accent3); }
  .phase-4 .phase-header { border-left: 3px solid var(--accent4); }
  .phase-5 .phase-header { border-left: 3px solid #bd93f9; }
  .phase-6 .phase-header { border-left: 3px solid #ffb86c; }

  /* Complete banner */
  .complete-banner {
    display: none;
    text-align: center;
    padding: 32px;
    background: rgba(0,255,136,0.05);
    border: 1px solid rgba(0,255,136,0.2);
    border-radius: 8px;
    margin-top: 24px;
    animation: fadeUp 0.5s ease both;
  }

  .complete-banner.show { display: block; }
  .complete-banner h2 { font-size: 2rem; color: var(--accent); margin-bottom: 8px; }
  .complete-banner p { color: var(--muted); font-family: 'Space Mono', monospace; font-size: 12px; }

  /* Mobile tweaks */
  @media (max-width: 480px) {
    .link-grid { grid-template-columns: 1fr; }
    .stack-row { grid-template-columns: 1fr 1fr; }
    .stack-row .stack-cell:last-child { display: none; }
  }
</style>
</head>
<body>
<div class="noise"></div>

<div class="container">
  <header>
    <div class="logo-badge">// DevBase v1.0</div>
    <h1>Your <span>Secure</span> Dev<br>Environment</h1>
    <p class="subtitle">android · web · unlimited apps · 100% free</p>
  </header>

  <div class="progress-section">
    <div class="progress-header">
      <span class="progress-label">// SETUP PROGRESS</span>
      <span class="progress-count" id="prog-count">0 / 14 steps</span>
    </div>
    <div class="progress-bar">
      <div class="progress-fill" id="prog-fill"></div>
    </div>
  </div>

  <!-- PHASE 1 -->
  <div class="phase phase-1 open">
    <div class="phase-header" onclick="togglePhase(this)">
      <div class="phase-num">01</div>
      <div class="phase-title">Install Termux — Your Linux Core</div>
      <div class="phase-meta">~5 min</div>
      <div class="phase-arrow">▼</div>
    </div>
    <div class="phase-body">
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Install F-Droid (App Store)</div>
          <div class="step-desc">F-Droid has the real Termux. Play Store version is outdated and broken.</div>
          <div class="link-grid">
            <a class="link-card" href="https://f-droid.org" target="_blank"><span class="link-icon">⬇️</span> f-droid.org</a>
          </div>
        </div>
      </div>
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Install Termux from F-Droid</div>
          <div class="step-desc">Search "Termux" inside F-Droid and install it. This is your Linux terminal.</div>
        </div>
      </div>
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Bootstrap your environment</div>
          <div class="step-desc">Open Termux and run this command — it installs everything you need.</div>
          <div class="code-block">
            <div class="code-topbar">
              <span class="code-lang">bash</span>
              <button class="copy-btn" onclick="copyCode(this)">COPY</button>
            </div>
            <pre><span class="comment"># Update & install core tools</span>
<span class="cmd">pkg update && pkg upgrade -y && pkg install</span> git nodejs python curl wget unzip micro -y</pre>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- PHASE 2 -->
  <div class="phase phase-2">
    <div class="phase-header" onclick="togglePhase(this)">
      <div class="phase-num">02</div>
      <div class="phase-title">VS Code in Your Browser</div>
      <div class="phase-meta">~3 min</div>
      <div class="phase-arrow">▼</div>
    </div>
    <div class="phase-body">
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Install code-server</div>
          <div class="step-desc">This runs VS Code right in your phone's browser. Real editor, real extensions.</div>
          <div class="code-block">
            <div class="code-topbar">
              <span class="code-lang">bash</span>
              <button class="copy-btn" onclick="copyCode(this)">COPY</button>
            </div>
            <pre><span class="cmd">npm install -g code-server</span></pre>
          </div>
        </div>
      </div>
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Launch VS Code</div>
          <div class="step-desc">Run this, then open <strong style="color:#00ff88">http://localhost:8080</strong> in your browser.</div>
          <div class="code-block">
            <div class="code-topbar">
              <span class="code-lang">bash</span>
              <button class="copy-btn" onclick="copyCode(this)">COPY</button>
            </div>
            <pre><span class="cmd">code-server</span> --bind-addr 127.0.0.1:8080 --auth none</pre>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- PHASE 3 -->
  <div class="phase phase-3">
    <div class="phase-header" onclick="togglePhase(this)">
      <div class="phase-num">03</div>
      <div class="phase-title">Build Web Apps — React / Next.js</div>
      <div class="phase-meta">~5 min</div>
      <div class="phase-arrow">▼</div>
    </div>
    <div class="phase-body">
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Create your first React app</div>
          <div class="step-desc">Creates a full React project. Run unlimited times with different names.</div>
          <div class="code-block">
            <div class="code-topbar">
              <span class="code-lang">bash</span>
              <button class="copy-btn" onclick="copyCode(this)">COPY</button>
            </div>
            <pre><span class="comment"># Create a new web app</span>
<span class="cmd">npx create-react-app</span> my-app
<span class="cmd">cd</span> my-app && <span class="cmd">npm start</span>
<span class="comment"># Opens at http://localhost:3000</span></pre>
          </div>
        </div>
      </div>
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Or use Next.js (recommended)</div>
          <div class="step-desc">Next.js is more powerful — handles routing, APIs, SEO, and deployment automatically.</div>
          <div class="code-block">
            <div class="code-topbar">
              <span class="code-lang">bash</span>
              <button class="copy-btn" onclick="copyCode(this)">COPY</button>
            </div>
            <pre><span class="cmd">npx create-next-app@latest</span> my-app --js --tailwind --no-eslint
<span class="cmd">cd</span> my-app && <span class="cmd">npm run dev</span></pre>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- PHASE 4 -->
  <div class="phase phase-4">
    <div class="phase-header" onclick="togglePhase(this)">
      <div class="phase-num">04</div>
      <div class="phase-title">Build Android Apps — Expo</div>
      <div class="phase-meta">~5 min</div>
      <div class="phase-arrow">▼</div>
    </div>
    <div class="phase-body">
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Install Expo Go on your phone</div>
          <div class="step-desc">Get it from Play Store — this lets you preview any app instantly on your real device.</div>
          <div class="link-grid">
            <a class="link-card" href="https://play.google.com/store/apps/details?id=host.exp.exponent" target="_blank"><span class="link-icon">📱</span> Expo Go</a>
          </div>
        </div>
      </div>
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Create your first Android app</div>
          <div class="step-desc">Scan the QR code it generates with Expo Go to see your app live on your phone.</div>
          <div class="code-block">
            <div class="code-topbar">
              <span class="code-lang">bash</span>
              <button class="copy-btn" onclick="copyCode(this)">COPY</button>
            </div>
            <pre><span class="cmd">npx create-expo-app@latest</span> MyApp
<span class="cmd">cd</span> MyApp && <span class="cmd">npx expo start</span>
<span class="comment"># Scan QR code with Expo Go app</span></pre>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- PHASE 5 -->
  <div class="phase phase-5">
    <div class="phase-header" onclick="togglePhase(this)">
      <div class="phase-num">05</div>
      <div class="phase-title">Backend + Database</div>
      <div class="phase-meta">~5 min</div>
      <div class="phase-arrow">▼</div>
    </div>
    <div class="phase-body">
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Create a Node.js API server</div>
          <div class="step-desc">Express is the #1 backend framework. Powers your app's data, auth, and logic.</div>
          <div class="code-block">
            <div class="code-topbar">
              <span class="code-lang">bash</span>
              <button class="copy-btn" onclick="copyCode(this)">COPY</button>
            </div>
            <pre><span class="cmd">mkdir</span> my-api && <span class="cmd">cd</span> my-api
<span class="cmd">npm init -y</span>
<span class="cmd">npm install</span> express cors dotenv
<span class="comment"># Then create server.js in VS Code</span></pre>
          </div>
          <div class="code-block" style="margin-top:6px">
            <div class="code-topbar">
              <span class="code-lang">javascript — server.js</span>
              <button class="copy-btn" onclick="copyCode(this)">COPY</button>
            </div>
            <pre><span class="kw">const</span> express = <span class="cmd">require</span>(<span class="str">'express'</span>)
<span class="kw">const</span> app = <span class="cmd">express</span>()
app.<span class="cmd">use</span>(express.<span class="cmd">json</span>())

app.<span class="cmd">get</span>(<span class="str">'/'</span>, (req, res) => {
  res.<span class="cmd">json</span>({ status: <span class="str">'API running 🚀'</span> })
})

app.<span class="cmd">listen</span>(<span class="str">3001</span>, () => <span class="cmd">console</span>.<span class="cmd">log</span>(<span class="str">'Server on :3001'</span>))</pre>
          </div>
        </div>
      </div>
      <div class="step" onclick="toggleStep(this)">
        <div class="step-check">✓</div>
        <div class="step-content">
          <div class="step-title">Free cloud database — MongoDB Atlas</div>
